# Auto-detect text files and perform LF normalization
* text=auto

# Shell scripts should always use LF
*.sh text eol=lf

# PowerShell scripts should use CRLF on Windows
*.ps1 text eol=crlf

# Python scripts should use LF
*.py text eol=lf

# Batch files should use CRLF
*.bat text eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.exe binary